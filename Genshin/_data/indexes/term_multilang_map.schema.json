{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Term Multilingual Map",
  "description": "Multilingual terminology map for search and cross-reference. NOT lore evidence.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "term_id",
      "canonical_term",
      "term_type",
      "names",
      "confidence",
      "ambiguity_status"
    ],
    "properties": {
      "term_id": {
        "type": "string",
        "description": "Internal term identifier"
      },
      "canonical_term": {
        "type": "string",
        "description": "Primary English term"
      },
      "term_type": {
        "type": "string",
        "description": "Term classification",
        "enum": [
          "character",
          "organization",
          "location",
          "region",
          "story_term",
          "quest",
          "artifact",
          "weapon",
          "item",
          "unknown"
        ]
      },
      "names": {
        "type": "object",
        "description": "Known term forms per language",
        "properties": {
          "en": { "type": "array", "items": { "type": "string" } },
          "vi": { "type": "array", "items": { "type": "string" } },
          "zhCN": { "type": "array", "items": { "type": "string" } },
          "zhTW": { "type": "array", "items": { "type": "string" } },
          "ja": { "type": "array", "items": { "type": "string" } }
        }
      },
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Category/classification tags from source"
      },
      "source_references": {
        "type": "array",
        "items": { "type": "string" },
        "description": "External sources that contributed this entry"
      },
      "confidence": {
        "type": "string",
        "enum": ["high", "medium", "low", "unknown"]
      },
      "ambiguity_status": {
        "type": "string",
        "enum": ["unique", "ambiguous", "conflict", "needs_human_review", "deferred_missing_local_data"]
      },
      "notes": {
        "type": "string",
        "description": "Additional context or disambiguation notes"
      }
    }
  },
  "_meta": {
    "status": "deferred_missing_local_data",
    "created_by": "Pass 25.7",
    "not_canon_evidence": true
  }
}
